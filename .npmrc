# The dependency tree has peer conflicts that npm's strict resolver rejects
# (e.g. @posthog/ai peerOptional @anthropic-ai/sdk ^0.78.0 vs
# @anthropic-ai/claude-agent-sdk peer @anthropic-ai/sdk >=0.93.0, pulled by the
# built-in claude-agent-sdk provider). Install with the legacy resolver so the
# lockfile (also generated with --legacy-peer-deps) installs cleanly in CI and
# the Docker image build.
legacy-peer-deps=true
